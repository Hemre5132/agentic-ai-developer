# Copy to `.env` or `supabase/.env.local` (gitignored) and fill locally.
# Never commit real values. Dashboard: Supabase → Settings → API; Edge → Secrets.

# --- Supabase (hosted) ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Google Gemini (Edge secrets or local serve) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# --- Optional: local Supabase (`supabase start`) ---
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_SERVICE_ROLE_KEY=paste_from_supabase_status

# --- iOS (usually Xcode Info.plist; listed here for one-place reference) ---
# SUPABASE_PROJECT_URL=https://YOUR_PROJECT_REF.supabase.co

# --- Issue reports (Edge `submit-issue-report`: DB + Resend email) ---
# Set as Supabase Edge secrets (not in iOS plist).
# RESEND_API_KEY=re_...
# RESEND_FROM=onboarding@resend.dev
# REPORT_TO_EMAIL=aliozten92@gmail.com
# Testing only — skip UTC-day rate limit in Edge (remove in production):
# ISSUE_REPORT_BYPASS_UTC_RATE_LIMIT=true
